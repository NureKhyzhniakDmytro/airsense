# AirSense local secrets and Firebase configuration
# Copy this file to .env and fill real values:
#   cp .env.example .env
#   nano .env
# Then run:
#   ./scripts/deploy-minikube.sh
#   ./scripts/expose-minikube-ingress.sh

# PostgreSQL. Use a non-default password for real demo data.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-postgres-password"
POSTGRES_DATABASE="airsensedb"

# MQTT internal API password used by backend services.
MQTT_API_PASSWORD="change-me-mqtt-api-password"

# Backend Firebase Admin configuration.
# Put your Firebase service account JSON outside git, for example:
#   /opt/airsense/secrets/firebase-service-account.json
# The deploy script loads this file into a Kubernetes Secret and mounts it into backend pods.
FIREBASE_PROJECT_NAME="airsense-nure"
FIREBASE_CREDENTIALS_JSON_FILE="/opt/airsense/secrets/firebase-service-account.json"

# Frontend Firebase Web SDK configuration.
# Firebase console -> Project settings -> General -> Your apps -> Web app config.
FRONTEND_FIREBASE_API_KEY=""
FRONTEND_FIREBASE_AUTH_DOMAIN="airsense-nure.firebaseapp.com"
FRONTEND_FIREBASE_PROJECT_ID="airsense-nure"
FRONTEND_FIREBASE_STORAGE_BUCKET="airsense-nure.firebasestorage.app"
FRONTEND_FIREBASE_MESSAGING_SENDER_ID=""
FRONTEND_FIREBASE_APP_ID=""
FRONTEND_FIREBASE_MEASUREMENT_ID=""
# Firebase console -> Project settings -> Cloud Messaging -> Web Push certificates.
FRONTEND_FIREBASE_VAPID_KEY=""
